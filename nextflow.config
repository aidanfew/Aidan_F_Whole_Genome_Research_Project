// ---------------------------------------------------------------------------
// nextflow.config  —  BYU Research Supercomputer (SLURM)
// ---------------------------------------------------------------------------

// Default work directory (temp files, staging)
workDir = '/home/aidanfew/work/nextflow_work'

// ---------------------------------------------------------------------------
// Default process settings — conservative baseline
// ---------------------------------------------------------------------------
process {
    executor      = 'slurm'
    queue         = 'm9'
    cpus          = 4
    memory        = '16 GB'
    time          = '04:00:00'
    errorStrategy = 'retry'
    maxRetries    = 2

    // -------------------------------------------------------------------------
    // Per-process resource overrides
    // SPLIT_VCF:       vcftools on a 50-100 GB bgz — mostly I/O, modest RAM
    // MAKE_BIM_BED_FAM: plink2 on per-chrom VCF — moderate RAM
    // MAKE_PHENO:      awk only — tiny
    // MAKE_GRM:        GCTA GRM on WGS data — memory-hungry, allow long runtime
    // MAKE_MGRM_LIST:  shell only — tiny
    // RUN_GREML:       GCTA REML with 22 GRMs — substantial RAM, long runtime
    // -------------------------------------------------------------------------
    withName: 'SPLIT_VCF' {
        cpus   = 2
        memory = '32 GB'
        time   = '08:00:00'
    }
    withName: 'MAKE_BIM_BED_FAM' {
        cpus   = 4
        memory = '32 GB'
        time   = '04:00:00'
    }
    withName: 'MAKE_PHENO' {
        cpus   = 1
        memory = '4 GB'
        time   = '00:30:00'
    }
    withName: 'MAKE_GRM' {
        cpus   = 8
        memory = '128 GB'
        time   = '12:00:00'
    }
    withName: 'MAKE_MGRM_LIST' {
        cpus   = 1
        memory = '4 GB'
        time   = '00:15:00'
    }
    withName: 'RUN_GREML' {
        cpus   = 8
        memory = '64 GB'
        time   = '08:00:00'
    }
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------
profiles {

    // Default profile — uses settings above
    slurm {
        process.executor = 'slurm'
        process.queue    = 'm9'
    }

    // Local testing profile (small test subset, no SLURM)
    local {
        process.executor = 'local'
        process.cpus     = 2
        process.memory   = '8 GB'
    }
}

// Cache mode: lenient allows minor file timestamp changes without invalidating cache
process.cache = 'lenient'

trace {
    overwrite = true
}

report {
    overwrite = true
}

timeline {
    overwrite = true
}

dag {
    overwrite = true
}
